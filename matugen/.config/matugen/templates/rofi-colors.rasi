/* matugen tarafından üretildi — ELLE DÜZENLEME (soft-light nötr) */
* {
    bg:        {{colors.surface_dim.default.hex_alpha | set_alpha: 0.93}};
    bg-alt:    {{colors.surface_container_high.default.hex}};
    bg-sel:    #A84538;
    fg:        {{colors.on_surface.default.hex}};
    fg-dim:    {{colors.on_surface_variant.default.hex}};
    accent:    #A84538;
    accent-br: #CA5746;
    line:      {{colors.outline_variant.default.hex}};
}
